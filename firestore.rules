rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email == 'arezlebnen_2017_admin@gmail.com';
    }

    match /catalogo_menudeo/{productoId} {
      allow read: if resource.data.activo == true;
      allow write: if isAdmin();
    }

    match /catalogo_mayoreo/{productoId} {
      allow read: if signedIn() && resource.data.activo_mayoreo == true;
      allow write: if isAdmin();
    }

    match /productos_admin/{productoId} {
      allow read, write: if isAdmin();
    }
  }
}
